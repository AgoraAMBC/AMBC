# ============================================================
# CONFIGURAÇÃO DO BANCO DE DADOS — AMBC V2
# ============================================================
# Copie este arquivo para .env e preencha com as credenciais.
# O arquivo .env NUNCA deve ser commitado (está no .gitignore).
#
# OPÇÃO 1 — Banco compartilhado do Render (recomendado para o time)
# Peça as credenciais ao responsável pelo projeto.
# ============================================================

DB_HOST=dpg-xxxxxxxxx.ohio-postgres.render.com
DB_PORT=5432
DB_NAME=ambc_db
DB_USER=ambc_db_user
DB_PASS=sua_senha_aqui
DB_SSLMODE=require

# ============================================================
# OPÇÃO 2 — Banco local (Laragon / PostgreSQL local)
# Use apenas para desenvolvimento offline.
# ============================================================

# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=AMBC
# DB_USER=banco_user
# DB_PASS=sua_senha_local
# DB_SSLMODE=disable
