# AMBC V2 — Apache production config
# Hostinger shared hosting (subdomain)

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Bloqueia acesso direto ao .env
    RewriteRule ^\.env$ - [F,L]

    # Serve arquivos e diretórios reais (assets, views, backend)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Redireciona tudo mais para index.html (SPA hash routing)
    RewriteRule ^ index.html [L]
</IfModule>

# Segurança: bloqueia acesso a arquivos sensíveis
<FilesMatch "(^\.env|composer\.json|composer\.lock|package\.json|package-lock\.json)$">
    Require all denied
</FilesMatch>

# Compressão gzip para assets
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# Cache de assets estáticos
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css             "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png            "access plus 1 month"
    ExpiresByType image/jpg            "access plus 1 month"
    ExpiresByType image/jpeg           "access plus 1 month"
    ExpiresByType image/svg+xml        "access plus 1 month"
    ExpiresByType image/x-icon         "access plus 1 year"
    ExpiresByType text/html            "access plus 0 seconds"
</IfModule>

# PHP: limites para upload de documentos
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 15M
    php_value memory_limit 128M
    php_value max_execution_time 30
</IfModule>
